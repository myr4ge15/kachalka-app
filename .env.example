# Скопируй этот файл в .env и подставь свои значения из Supabase
# (Project Settings → API Keys). .env в git не попадает (см. .gitignore).
#
# VITE_SUPABASE_KEY — это publishable-ключ (sb_publishable_...), он публичный
# по задумке. Секретный ключ (sb_secret_...) сюда вписывать НЕ нужно.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
